{
  "name": "keepsake",
  "description": "Keepsake \u2014 an AI-powered MV3 bookmark manager. Local-first, with an optional PocketBase backend.",
  "private": true,
  "version": "8.16.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test:retrieval": "node --test scripts/test-retrieval.mjs",
    "test:bulk": "node --test scripts/test-bulk.mjs",
    "test:ui": "node --test scripts/test-ui-context.mjs",
    "test:quickbar": "node --test scripts/test-quickbar-config.mjs",
    "test:tooltips": "node --test scripts/test-quickbar-tooltips.mjs",
    "test:writer": "node --test scripts/test-ai-writer.mjs",
    "test:models": "node --test scripts/test-model-router.mjs",
    "test:ai-upgrade": "node --test scripts/test-ai-812.mjs",
    "test:performance": "node --test scripts/test-performance-surfaces.mjs",
    "test:reliability": "node --test scripts/test-reliability-safety.mjs",
    "test:startup": "node --test scripts/test-startup-polish.mjs",
    "test:capture": "node --test scripts/test-capture-813.mjs",
    "test:home-fast-814": "node --test scripts/test-home-fast-814.mjs",
    "test:capture-814": "node --test scripts/test-capture-814.mjs",
    "test:content-814": "node --test scripts/test-content-814.mjs",
    "test:brand-814": "node --test scripts/test-brand-814.mjs",
    "test:visual-performance-814": "node --test scripts/test-visual-performance-814.mjs",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "test": "npm run test:retrieval && npm run test:bulk && npm run test:ui && npm run test:quickbar && npm run test:tooltips && npm run test:writer && npm run test:models && npm run test:ai-upgrade && npm run test:performance && npm run test:reliability && npm run test:startup && npm run test:capture && npm run test:home-fast-814 && npm run test:capture-814 && npm run test:content-814 && npm run test:brand-814 && npm run test:visual-performance-814 && npm run test:ai-reliability-815 && npm run test:ai-polish-8151 && npm run test:ai-selection-816 && npm run test:widget-canvas-816 && npm run test:ai-runtime-816 && npm run test:home-cold-start-816",
    "check:version": "node scripts/check-version.mjs",
    "check": "npm run check:version && npm test && npm run compile && npm run build",
    "postinstall": "wxt prepare",
    "zip:store": "WXT_STORE=1 wxt zip",
    "test:ai-reliability-815": "node --test scripts/test-ai-reliability-815.mjs",
    "test:ai-polish-8151": "node --test scripts/test-ai-polish-8151.mjs",
    "test:ai-selection-816": "node --test scripts/test-ai-selection-816.mjs",
    "test:widget-canvas-816": "node --test scripts/test-widget-canvas-816.mjs",
    "test:ai-runtime-816": "node --test scripts/test-ai-action-runtime-816.mjs",
    "test:home-cold-start-816": "node --test scripts/test-home-cold-start-816.mjs",
    "check:home-startup-bundle": "node scripts/check-home-startup-bundle.mjs"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dexie": "^4.4.4",
    "pocketbase": "^0.26.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
