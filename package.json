{
  "name": "keepsake",
  "description": "Keepsake — an AI-powered MV3 bookmark manager. Local-first, with an optional PocketBase backend.",
  "private": true,
  "version": "8.10.1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "test:retrieval": "node --test scripts/test-retrieval.mjs",
    "test:bulk": "node --test scripts/test-bulk.mjs",
    "test:ui": "node --test scripts/test-ui-context.mjs",
    "test": "npm run test:retrieval && npm run test:bulk && npm run test:ui",
    "check:version": "node scripts/check-version.mjs",
    "check": "npm run check:version && npm test && npm run compile && npm run build",
    "postinstall": "wxt prepare",
    "zip:store": "WXT_STORE=1 wxt zip"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "dexie": "^4.4.4",
    "pocketbase": "^0.26.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.4.20",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.49",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wxt": "^0.20.0"
  }
}
